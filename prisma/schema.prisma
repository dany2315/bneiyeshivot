generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum ServiceRequestType {
  VISA_STUDENT
  KOUPAT_HOLIM
  GENERAL_CONTACT
}

enum ServiceRequestStatus {
  SUBMITTED
  IN_REVIEW
  MISSING_DOCUMENTS
  APPROVED
  REJECTED
  COMPLETED
}

enum PaymentProvider {
  STRIPE
  NEDARIM_PLUS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELED
}

enum DonationFrequency {
  ONE_TIME
  MONTHLY
}

enum DonationSource {
  ONLINE
  ADMIN_CASH
  ADMIN_CHECK
  ADMIN_BANK_TRANSFER
  ADMIN_OTHER
}

enum CerfaReceiptType {
  PARTICULIER
  ENTREPRISE
  ISF_IFI
  AUTRE
}

enum DocumentStatus {
  MISSING
  REQUESTED
  RECEIVED
  REJECTED
  VALIDATED
}

enum EventRegistrationStatus {
  SUBMITTED
  CONFIRMED
  WAITLISTED
  CANCELED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY
  DELIVERED
  CANCELED
}

enum StoreReservationStatus {
  SUBMITTED
  CONFIRMED
  PREPARING
  READY
  COLLECTED
  CANCELED
}

enum MivhanRegistrationStatus {
  REGISTERED
  PRESENT
  ABSENT
  GRADED
  CANCELED
}

enum ReceiptStatus {
  NOT_REQUESTED
  REQUESTED
  GENERATED
  SENT
}

enum DvarTorahCategory {
  CHABBAT
  FETE
}

model User {
  id                  String               @id @default(cuid())
  name                String               @default("")
  email               String               @unique
  emailVerified       Boolean              @default(false)
  image               String?
  firstName           String?
  lastName            String?
  phone               String?
  parentPhone         String?
  yeshiva             String?
  programType         String?
  role                UserRole             @default(CLIENT)
  sessions            Session[]
  accounts            Account[]
  requests            ServiceRequest[]
  donations           Donation[]
  eventRegistrations  EventRegistration[]
  orders              Order[]
  storeReservations   StoreReservation[]
  mivhanRegistrations MivhanRegistration[]
  assignedRequests    ServiceRequest[]     @relation("AssignedRequests")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Storefront {
  id              String         @id @default(cuid())
  name            String         @default("Boutique Bnei Yeshivot")
  slug            String         @unique @default("boutique")
  description     String
  heroTitle       String         @default("Boutique literie")
  heroSubtitle    String
  pickupDetails   String?
  contactEmail    String?
  contactPhone    String?
  active          Boolean        @default(true)
  products        StoreProduct[]
  reservations    StoreReservation[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model StoreProduct {
  id             String                 @id @default(cuid())
  storefrontId   String
  storefront     Storefront             @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  title          String
  slug           String                 @unique
  description    String
  details        String?
  priceCents     Int
  currency       String                 @default("EUR")
  imageUrl       String?
  stockQuantity  Int?
  active         Boolean                @default(true)
  featured       Boolean                @default(false)
  reservationItems StoreReservationItem[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([storefrontId, active])
}

model StoreReservation {
  id            String                 @id @default(cuid())
  storefrontId  String
  storefront    Storefront             @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?                  @relation(fields: [userId], references: [id])
  status        StoreReservationStatus @default(SUBMITTED)
  customerName  String
  customerEmail String
  customerPhone String?
  yeshiva       String?
  arrivalDate   DateTime?
  note          String?
  adminNote     String?
  totalCents    Int
  currency      String                 @default("EUR")
  items         StoreReservationItem[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
}

model StoreReservationItem {
  id            String           @id @default(cuid())
  reservationId String
  reservation   StoreReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  productId     String
  product       StoreProduct     @relation(fields: [productId], references: [id])
  quantity      Int
  unitCents     Int
  productTitle  String
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model ServiceRequest {
  id           String               @id @default(cuid())
  type         ServiceRequestType
  status       ServiceRequestStatus @default(SUBMITTED)
  userId       String?
  user         User?                @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedTo   User?                @relation("AssignedRequests", fields: [assignedToId], references: [id])
  payload      Json
  publicNote   String?
  internalNote String?
  documents    RequestDocument[]
  messages     RequestMessage[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model RequestDocument {
  id              String         @id @default(cuid())
  requestId       String
  request         ServiceRequest @relation(fields: [requestId], references: [id])
  label           String
  fileKey         String
  mimeType        String
  status          DocumentStatus @default(RECEIVED)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RequestMessage {
  id         String         @id @default(cuid())
  requestId  String
  request    ServiceRequest @relation(fields: [requestId], references: [id])
  authorId   String?
  body       String
  isInternal Boolean        @default(false)
  createdAt  DateTime       @default(now())
}

model Event {
  id            String              @id @default(cuid())
  title         String
  slug          String              @unique
  description   String
  content       Json?
  imageKey      String?
  requiresRegistration Boolean      @default(false)
  startsAt      DateTime
  endsAt        DateTime?
  location      String?
  capacity      Int?
  registrations EventRegistration[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model EventRegistration {
  id        String                  @id @default(cuid())
  eventId   String
  event     Event                   @relation(fields: [eventId], references: [id])
  userId    String?
  user      User?                   @relation(fields: [userId], references: [id])
  payload   Json
  status    EventRegistrationStatus @default(SUBMITTED)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([eventId, userId])
}

model Donation {
  id                    String            @id @default(cuid())
  userId                String?
  user                  User?             @relation(fields: [userId], references: [id])
  provider              PaymentProvider
  source                DonationSource    @default(ONLINE)
  status                PaymentStatus     @default(PENDING)
  frequency             DonationFrequency @default(ONE_TIME)
  amountCents           Int
  refundedAmountCents   Int               @default(0)
  currency              String
  donorEmail            String
  donorFirstName        String?
  donorLastName         String?
  donorName             String?
  donorPhone            String?
  dedication            String?
  receiptNeeded         Boolean           @default(false)
  receiptStatus         ReceiptStatus     @default(NOT_REQUESTED)
  stripeCheckoutSessionId String?          @unique
  stripePaymentIntentId String?           @unique
  stripeSubscriptionId  String?
  stripeCustomerId      String?
  failureReason         String?
  paidAt                DateTime?
  canceledAt            DateTime?
  refundedAt            DateTime?
  receipt               Receipt?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([donorEmail])
}

model Receipt {
  id           String           @id @default(cuid())
  donationId   String           @unique
  donation     Donation         @relation(fields: [donationId], references: [id])
  number       String           @unique
  type         CerfaReceiptType @default(PARTICULIER)
  fileKey      String?
  issuedAt     DateTime         @default(now())
  fiscalYear   Int
  donorName    String
  donorAddress String?
  donorZip     String?
  donorCity    String?
  donorCountry String?
  donorTaxId   String?
  legalNote    String?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  priceCents  Int
  currency    String      @default("EUR")
  active      Boolean     @default(true)
  orderItems  OrderItem[]
}

model Order {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  email      String
  status     OrderStatus @default(PENDING_PAYMENT)
  totalCents Int
  currency   String      @default("EUR")
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitCents Int
}

model MivhanSession {
  id                       String               @id @default(cuid())
  title                    String
  date                     DateTime
  location                 String?
  registrationCloseDaysBefore Int               @default(2)
  registrationsClosed      Boolean              @default(false)
  registrations            MivhanRegistration[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model MivhanRegistration {
  id                String                   @id @default(cuid())
  sessionId         String
  session           MivhanSession            @relation(fields: [sessionId], references: [id])
  userId            String?
  user              User?                    @relation(fields: [userId], references: [id])
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  yeshiva           String?
  massehet          String?
  dapim             String?
  dafStart          String?
  dafEnd            String?
  status            MivhanRegistrationStatus @default(REGISTERED)
  grade             Float?
  note              String?
  rewardAmountCents Int?
  rewardCurrency    String                   @default("ILS")
  rewardPaid        Boolean                  @default(false)
  resultPublishedAt DateTime?
  resultEmailSentAt DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([sessionId, userId])
  @@index([email])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model DvarTorahFile {
  id          String            @id @default(cuid())
  title       String
  slug        String            @unique
  description String?
  category    DvarTorahCategory
  fileKey     String
  fileUrl     String
  mimeType    String
  size        Int
  published   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}
